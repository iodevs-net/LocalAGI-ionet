# =============================================================================
# IONET - Variables de Entorno
# Copiar a .env y configurar según el entorno
# =============================================================================

# =============================================================================
# SECCIÓN 1: LLM Provider (OpenAI-compatible API)
# =============================================================================
# URL base del API (OpenRouter para máxima flexibilidad)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Clave API de OpenRouter
OPENAI_API_KEY=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

# Modelo para PRUEBAS GRATUITAS (Nemotron-3 Super 120B)
MODEL_NAME=inclusionai/ling-2.6-1t:free

# Modelo multimodal (Usando el mismo para pruebas)
MULTIMODAL_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# =============================================================================
# SECCIÓN 2: Seguridad
# =============================================================================
# API Keys separadas por coma para acceso a la API de IONET
# Ejemplo: key1,key2,key3
LOCALAGI_API_KEYS=tu-api-key-segura-aqui

# =============================================================================
# SECCIÓN 3: Configuración General
# =============================================================================
# Timeout para requests al LLM
TIMEOUT=5m

# Habilitar logging de conversaciones (true/false)
ENABLE_LOGGING=false

# URL base de la aplicación (usar dominio en producción)
LOCALAGI_BASE_URL=http://localhost:8080

# =============================================================================
# SECCIÓN 4: Base de Datos y RAG
# =============================================================================
# Motor de vectores: chromem (desarrollo) o postgres (producción)
VECTOR_ENGINE=chromem

# URL de PostgreSQL (requerido para VECTOR_ENGINE=postgres)
# En producción usar contraseña segura via variable de entorno
POSTGRES_PASSWORD=contraseña_segura_aqui

# URL completa de PostgreSQL
# DATABASE_URL=postgresql://ionet:${POSTGRES_PASSWORD}@postgres:5432/ionet?sslmode=disable

# Modelo para embeddings (requerido para RAG)
# Opciones:
#   - sentence-transformers/all-MiniLM-L6-v2 (lento, preciso)
#   - granite-embedding-107m-multilingual (mejor para español)
#   - bge-m3 (multilingual, rápido)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# SECCIÓN 5: Microsoft 365 / SharePoint (Opcional)
# =============================================================================
# Configuración para sincronizar documentos desde M365
# Registrar app en: https://portal.azure.com > App registrations

# Client ID del registro de app de Azure
M365_CLIENT_ID=

# Client Secret (generar en Certificates & secrets)
M365_CLIENT_SECRET=

# Tenant ID de Azure AD
M365_TENANT_ID=

# =============================================================================
# SECCIÓN 6: Producción (solo para docker-compose.prod.yaml)
# =============================================================================
# Tag de imagen para producción
IMAGE_TAG=latest

# =============================================================================
# NOTAS:
# - En desarrollo usar docker-compose.dev.yaml
# - En producción usar docker-compose.prod.yaml
# - Nunca commitear este archivo al repositorio
# =============================================================================

# =============================================================================
# SECCIÓN 6: ION Connectors (Email + Teams)
# =============================================================================
# Email connector - ION puede recibir/enviar emails
# Usar cuenta de Office 365 para ionet.cl
ION_EMAIL_USER=el.agente.ion@gmail.com
ION_EMAIL_PASSWORD=yyja fnfr pooh

# Teams connector - ION puede enviar notificaciones a Teams
# Crear webhook: Teams Channel > Connectors > Incoming Webhook
TEAMS_WEBHOOK_URL=https://ionet.webhook.office.com/webhookb2/xxx
