# IONET - Variables de entorno para producción
# Copiar a .env y configurar valores reales

# API LLM (MiniMax)
OPENAI_API_KEY=tu-api-key-aqui
OPENAI_BASE_URL=https://api.minimax.io/v1

# Modelos
LOCALAGI_MODEL=MiniMax-M2.7
LOCALAGI_MULTIMODAL_MODEL=MiniMax-M2.7
LOCALAGI_LLM_API_URL=https://api.minimax.io/v1
LOCALAGI_LLM_API_KEY=tu-api-key-aqui

# Seguridad
LOCALAGI_API_KEYS=token1,token2,token3

# Configuración
LOCALAGI_TIMEOUT=5m
LOCALAGI_ENABLE_CONVERSATIONS_LOGGING=false

# Base de datos
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=disable

# Opcional - M365
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_TENANT_ID=
