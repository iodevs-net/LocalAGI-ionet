# =============================================================================
# IONET Configuration - Turnkey Deployment
# =============================================================================
# Copy this file to .env and configure the values below.
# Solo necesitas editar este archivo con tus API keys.

# =============================================================================
# API Configuration
# =============================================================================
# MiniMax API (OpenAI-compatible)
OPENAI_API_KEY=your-minimax-api-key-here
OPENAI_BASE_URL=https://api.minimax.io/v1

# Model configuration
MODEL_NAME=MiniMax-M2.7
MULTIMODAL_MODEL=MiniMax-M2.7

# =============================================================================
# Optional: LocalAI (uncomment to use local models instead of MiniMax)
# =============================================================================
# OPENAI_BASE_URL=http://localai:8080
# OPENAI_API_KEY=localai
# MODEL_NAME=gemma-3-4b-it-qat

# =============================================================================
# Optional: PostgreSQL Knowledge Base
# =============================================================================
# VECTOR_ENGINE=postgres
# DATABASE_URL=postgresql://localrecall:localrecall@postgres:5432/localrecall?sslmode=disable
# EMBEDDING_MODEL=granite-embedding-107m-multilingual

# =============================================================================
# MCP Servers (HTTP) - Optional
# Format: JSON array of {"url":"https://...","token":"..."}
# =============================================================================
# LOCALAGI_MCP_SERVERS=[{"url":"https://mcp.server.com","token":"your-token"}]

# =============================================================================
# MCP Servers (STDIO) - Optional
# Format: JSON array of {"name":"server-name","cmd":"npx","args":["-y","@some/mcp-server"],"env":["KEY=val"]}
# =============================================================================
# LOCALAGI_MCP_STDIO_SERVERS=[{"name":"github","cmd":"docker","args":["run","-i","--rm","-e","GITHUB_PERSONAL_ACCESS_TOKEN","ghcr.io/github/github-mcp-server"],"env":["GITHUB_PERSONAL_ACCESS_TOKEN=your-token"]}]

# =============================================================================
# Optional: SSHBox Access
# =============================================================================
# LOCALAGI_SSHBOX_URL=root:root@sshbox:22

# =============================================================================
# General Settings
# =============================================================================
LOCALAGI_TIMEOUT=5m
LOCALAGI_ENABLE_CONVERSATIONS_LOGGING=false
