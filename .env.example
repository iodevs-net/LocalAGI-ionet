# =============================================================================
# IONET - Variables de entorno para producción
# Copiar a .env y configurar valores reales
# =============================================================================

# SECCIÓN 1: LLM Provider (OpenAI-compatible API)
# =============================================================================
# URL base del API (MiniMax para IONET)
OPENAI_BASE_URL=https://api.minimax.io/v1

# Clave API
OPENAI_API_KEY=tu-api-key-aqui

# Modelos
MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free
MULTIMODAL_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# SECCIÓN 2: Seguridad
# =============================================================================
# API Keys para acceder al servidor local (separadas por coma)
LOCALAGI_API_KEYS=token1,token2,token3

# SECCIÓN 3: Configuración General
# =============================================================================
# Timeout para requests al LLM
TIMEOUT=5m

# Habilitar logging de conversaciones (true/false)
ENABLE_LOGGING=false

# URL base de la aplicación (usar dominio en producción)
LOCALAGI_BASE_URL=https://agentes.ionet.cl

# =============================================================================
# SECCIÓN 4: Base de Datos y RAG
# =============================================================================
# Motor de vectores: chromem (desarrollo) o postgres (producción)
VECTOR_ENGINE=postgres

# Contraseña de PostgreSQL (configurar valor real en .env)
POSTGRES_PASSWORD=contraseña_segura_aqui

# Modelo para embeddings (requerido para RAG)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# SECCIÓN 5: Microsoft 365 / SharePoint (Opcional)
# =============================================================================
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_TENANT_ID=

# =============================================================================
# SECCIÓN 6: ION Connectors (Email + Teams)
# =============================================================================
# Email connector
ION_EMAIL_USER=soporte@ionet.cl
ION_EMAIL_PASSWORD=tu-app-password

# Teams connector
TEAMS_WEBHOOK_URL=https://ionet.webhook.office.com/webhookb2/xxx

# =============================================================================
# SECCIÓN 7: Producción
# =============================================================================
# Tag de imagen para producción
IMAGE_TAG=latest
